{
  "name": "ai-study-buddy-windows",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main-windows.cjs",
  "scripts": {
    "build": "vite build --config vite.config.windows.js",
    "build:electron": "electron-builder --win --x64 --publish=never",
    "build:all": "npm run build && npm run build:electron"
  },
  "build": {
    "appId": "com.nabstertsr.studybuddy.windows",
    "productName": "Nabster Study Buddy",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!**/*.map",
      "!**/node_modules/**/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/**/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/**/*.d.ts"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": "EULA.md",
      "shortcutName": "Study Buddy"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.26.0",
    "lucide-react": "^0.475.0",
    "framer-motion": "^11.18.2",
    "tailwind-merge": "^3.4.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.7.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  }
}